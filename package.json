{
  "name": "pawwellbot-app",
  "version": "1.0.0",
  "description": "Black and yellow placeholder website shell",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "start": "npm run dev:auto",
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:auto": "bash scripts/dev-server.sh",
    "dev:open": "vite --host 0.0.0.0 --port 5173 --open",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "vercel:link": "vercel link",
    "vercel:pull": "vercel pull",
    "deploy": "npm run deploy:preview",
    "deploy:check": "vercel deploy --dry --yes",
    "deploy:preview": "bash scripts/deploy-vercel.sh preview",
    "deploy:prod": "bash scripts/deploy-vercel.sh production"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
